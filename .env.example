# Polymarket (CLOB API)
POLYMARKET_PRIVATE_KEY=your_wallet_private_key_here
POLYMARKET_API_KEY=your_api_key_here
POLYMARKET_API_SECRET=your_api_secret_here
POLYMARKET_API_PASSPHRASE=your_passphrase_here

# Weather (Open-Meteo is free, no key needed)
# Optional: OpenWeatherMap for extra precision
OPENWEATHER_API_KEY=

# Bot config
DRY_RUN=true          # set false to place real orders
MAX_BET_USDC=5        # max bet per market in USDC
MIN_EDGE=0.05         # min edge to bet (5%)
LOG_LEVEL=info
