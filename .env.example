# ── Polymarket CLOB credentials ──────────────────────────────────────────────
# Get from https://clob.polymarket.com after connecting your wallet.
POLYMARKET_PRIVATE_KEY=0xYOUR_ETHEREUM_PRIVATE_KEY_HERE
POLYMARKET_ADDRESS=0xYOUR_ETHEREUM_ADDRESS_HERE
POLYMARKET_API_KEY=your_api_key_here
POLYMARKET_API_SECRET=your_api_secret_here
POLYMARKET_API_PASSPHRASE=your_passphrase_here

# ── Bot configuration ─────────────────────────────────────────────────────────
MAX_BET_USDC=10.0     # max bet per market in USDC
MIN_EDGE=0.05         # min edge to bet (5%)
LOG_LEVEL=info

# ── Telegram notifications (optional) ────────────────────────────────────────
# Create bot via @BotFather; get chat ID from @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Webhook notifications (optional, TASK-046) ────────────────────────────────
# POST JSON events to this URL (bet_placed, cycle_complete, error)
WEBHOOK_URL=

# ── Opportunity alerts (optional, TASK-165) ───────────────────────────────────
# Send a proactive Telegram alert when a market edge exceeds this threshold.
# 0 = disabled. Useful in dry-run or semi-manual mode.
OPPORTUNITY_ALERT_THRESHOLD=0.0
